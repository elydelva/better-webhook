{
  "name": "better-webhook",
  "private": true,
  "version": "0.0.0",
  "description": "Webhooks sortants fiables",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/elydelva/better-webhook" },
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "test": "bun test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version": "changeset version",
    "publish:packages": "changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.10",
    "bun-types": "^1.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "typescript": "^5.7.0"
  },
  "lint-staged": { "*.{ts,tsx}": "biome check --write" }
}
